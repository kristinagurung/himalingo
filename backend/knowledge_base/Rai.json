[{"english":"Hello","rai":"सेዋརོ་","transliteration_rai":"Khamma"},{"english":"How are you?","rai":"अन्खाया चिन?","transliteration_rai":"Ankhaya chin?"},{"english":"I am fine","rai":"नुवा चिन","transliteration_rai":"Nuwa chin"},{"english":"Thank you","rai":"धनीवाद","transliteration_rai":"Dhanyabad"},{"english":"What is your name?","rai":"अनाया नाम छिओ?","transliteration_rai":"Anaya nam chhio?"},{"english":"Where are you from?","rai":"अन्खाया ना का ता?","transliteration_rai":"Ankhaya na ka ta?"},{"english":"Water","rai":"वा","transliteration_rai":"Wa"},{"english":"Food","rai":"जा","transliteration_rai":"Ja"},{"english":"How much does this cost?","rai":"आय मय छिओ?","transliteration_rai":"Aaya may chhio?"},{"english":"Where is the bathroom?","rai":"खिम्पा खिम्पी?","transliteration_rai":"Khimpa khimpi?"},{"english":"It is very delicious","rai":"नुवा चा चिन","transliteration_rai":"Nuwa cha chin"},{"english":"Please give me some tea","rai":"का चिया पिरा","transliteration_rai":"Ka chiya pira"},{"english":"Stop the car here","rai":"गाडी ना का चो","transliteration_rai":"Gadi na ka cho"},{"english":"I am sick / I don't feel well","rai":"का नुवा मेचीन","transliteration_rai":"Ka nuwa me-chin"},{"english":"What time is it?","rai":"अय छिओ?","transliteration_rai":"Ay chhio?"},{"english":"Happy New Year","rai":"नुवा खिम्पा","transliteration_rai":"Nuwa khimpa"},{"english":"Do you speak English?","rai":"अनाया अङ्ग्रेजी बाते छिओ?","transliteration_rai":"Anaya Angrezi bate chhio?"},{"english":"I don't understand","rai":"का बुझे माचिन","transliteration_rai":"Ka bujhe ma-chin"},{"english":"Please speak slowly","rai":"नुवा नुवा बातेरा","transliteration_rai":"Nuwa nuwa batera"},{"english":"Can you help me?","rai":"का ग्वा बातेरा?","transliteration_rai":"Ka gwa batera?"},{"english":"I am lost","rai":"का लाम मेचीन","transliteration_rai":"Ka lam me-chin"},{"english":"Wait a minute","rai":"एका चिन चो","transliteration_rai":"Eka chin cho"},{"english":"Is it far?","rai":"खिम्पा छिओ?","transliteration_rai":"Khimpa chhio?"},{"english":"Call a doctor","rai":"डाक्टर को हिको","transliteration_rai":"Doctor ko hiko"},{"english":"How is the weather today?","rai":"अन्खाया नम छिओ?","transliteration_rai":"Ankhaya nam chhio?"},{"english":"Is there snow on the mountain?","rai":"हिउँ छिओ?","transliteration_rai":"Hiu chhio?"},{"english":"I want to go to the river","rai":"का वा पिरा","transliteration_rai":"Ka wa pira"},{"english":"It is very cold","rai":"चिसो चिन","transliteration_rai":"Chiso chin"},{"english":"Tomorrow morning","rai":"नुवा भोलि","transliteration_rai":"Nuwa bholi"},{"english":"One, Two, Three","rai":"वाक्च, हयाक्च, साक्च","transliteration_rai":"Wakcha, Hyakcha, Sakcha"},{"english":"Is the path dangerous?","rai":"लाम खतर छिओ?","transliteration_rai":"Lam khatara chhio?"}]
