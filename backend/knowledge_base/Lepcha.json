[{"english":"Hello","lepcha":"ᰀᰝᰵᰛᰧ","transliteration_lepcha":"Khamri"},{"english":"How are you?","lepcha":"ᰀᰝᰵᰛᰧ ᰣᰦᰆᰚᰨ?","transliteration_lepcha":"Khamri aachyo?"},{"english":"I am fine","lepcha":"ᰣᰦᰆᰚᰨ ᰜᰚᰵ","transliteration_lepcha":"Aachyo lyang"},{"english":"Thank you","lepcha":"ᰡᰬᰀᰪᰏᰪᰵ","transliteration_lepcha":"She-ku-nyon"},{"english":"What is your name?","lepcha":"ᰣᰦᰌᰨ ᰣᰦᰕᰧᰵ ᰀᰚᰦ?","transliteration_lepcha":"Aado a-ming kya?"},{"english":"Where are you from?","lepcha":"ᰣᰦᰌᰨ ᰜᰚᰵ ᰀᰚᰦ?","transliteration_lepcha":"Aado lyang kya?"},{"english":"Water","lepcha":"ᰣᰪᰵ","transliteration_lepcha":"Ung"},{"english":"Food","lepcha":"ᰦᰈᰨ","transliteration_lepcha":"Zo"},{"english":"How much does this cost?","lepcha":"ᰣᰦᰛᰬ ᰀᰚᰦ ᰃᰨᰵ?","transliteration_lepcha":"A-re kya gong?"},{"english":"Where is the bathroom?","lepcha":"ᰈᰀᰨᰵ ᰜᰚᰵ ᰀᰚᰦ?","transliteration_lepcha":"Jakong lyang kya?"},{"english":"It is very delicious","lepcha":"ᰣᰦᰕᰚᰬᰜ ᰆᰨ","transliteration_lepcha":"A-myel cho"},{"english":"Please give me some tea","lepcha":"ᰀᰵ ᰆᰦ ᰦᰈᰨ","transliteration_lepcha":"Ang cha a-zo"},{"english":"Stop the car here","lepcha":"ᰃᰦᰛᰧ ᰣᰦᰛᰬ ᰌᰨ","transliteration_lepcha":"Gari a-re do"},{"english":"I am sick / I don't feel well","lepcha":"ᰀᰵ ᰣᰦᰈᰬᰵ ᰕᰦᰵ","transliteration_lepcha":"Ang a-jen maang"},{"english":"What time is it?","lepcha":"ᰀᰚᰦ ᰃᰦᰛᰧ?","transliteration_lepcha":"Kya gari?"},{"english":"Happy New Year","lepcha":"ᰣᰦᰕᰚᰬᰜ ᰜᰨᰠᰦᰛ","transliteration_lepcha":"A-myel Losar"},{"english":"Do you speak English?","lepcha":"ᰣᰦᰌᰨ ᰣᰦᰵᰃᰛᰬᰈᰧᰵ ᰦᰛᰬ?","transliteration_lepcha":"Aado Angreji are?"},{"english":"I don't understand","lepcha":"ᰀᰵ ᰕᰦᰵ ᰦᰛᰬ","transliteration_lepcha":"Ang maang are"},{"english":"Please speak slowly","lepcha":"ᰣᰦᰆᰚᰨ ᰜᰬ ᰦᰈᰨ","transliteration_lepcha":"Aachyo le a-zo"},{"english":"Can you help me?","lepcha":"ᰀᰵ ᰣᰦᰕᰚᰬᰜ ᰦᰈᰨ?","transliteration_lepcha":"Ang a-myel a-zo?"},{"english":"I am lost","lepcha":"ᰀᰵ ᰜᰚᰵ ᰕᰦᰵ ᰦᰛᰬ","transliteration_lepcha":"Ang lyang maang are"},{"english":"Wait a minute","lepcha":"ᰣᰦᰆᰚᰨ ᰌᰨ","transliteration_lepcha":"Aachyo do"},{"english":"Is it far?","lepcha":"ᰜᰚᰵ ᰀᰚᰦ?","transliteration_lepcha":"Lyang kya?"},{"english":"Call a doctor","lepcha":"ᰣᰬᰕᰆᰧ ᰦᰈᰨ","transliteration_lepcha":"Amchi a-zo"},{"english":"How is the weather today?","lepcha":"ᰣᰦᰜᰨᰵ ᰜᰚᰵ ᰀᰚᰦ?","transliteration_lepcha":"A-long lyang kya?"},{"english":"Is there snow on the mountain?","lepcha":"ᰆᰪ ᰜᰚᰵ ᰀᰚᰦ?","transliteration_lepcha":"Chu lyang kya?"},{"english":"I want to go to the river","lepcha":"ᰀᰵ ᰣᰪᰵ ᰜᰚᰵ ᰦᰈᰨ","transliteration_lepcha":"Ang ung lyang a-zo"},{"english":"It is very cold","lepcha":"ᰣᰦᰆᰚᰨ ᰆᰪ","transliteration_lepcha":"Aachyo chu"},{"english":"Tomorrow morning","lepcha":"ᰜᰨᰀ ᰣᰦᰆᰚᰨ","transliteration_lepcha":"Lok aachyo"},{"english":"One, Two, Three","lepcha":"ᰀᰵᰳ ᰀᰵᰴ ᰀᰵᰴ","transliteration_lepcha":"Kat, Nyet, Sam"},{"english":"Is the path dangerous?","lepcha":"ᰜᰚᰵ ᰀᰚᰦ?","transliteration_lepcha":"Lyang kya?"}]
